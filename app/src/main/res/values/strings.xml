    <!-- Populates the "Recommended" section in LSPosed Manager's scope picker.
         The module's own process does NOT need to be ticked: the writable
         IXposedService binder is delivered to our manifest-declared
         XposedProvider when this UID starts (independent of hook scope), so
         MainActivity publishes edits straight to RemotePreferences over that
         binder. Self-scoping is unnecessary.
         - com.google.android.gms is listed because AdvertisingIdHooks and
           AppSetIdHooks have server-side hook paths that only run when GMS is
           in scope; without it the client-side hooks still work but apps that
           bypass them via raw AIDL will read the real ID from GMS. -->
    <string-array name="xposed_scope">
        <item>com.google.android.gms</item>
    </string-array>
