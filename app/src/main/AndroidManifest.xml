<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DeviceSpoofLab">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Authority must match <applicationId>.XposedService
             (io.github.libxposed.service.IXposedService.AUTHORITY_SUFFIX). -->
        <provider
            android:name="io.github.libxposed.service.XposedProvider"
            android:authorities="com.devicespooflab.hooks.XposedService"
            android:exported="true" />

        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <meta-data
            android:name="xposeddescription"
            android:value="@string/xposed_description" />

        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <!-- Semicolon-separated string instead of @array resource. Vector's
             parasitic Manager (running inside com.android.shell) fails on
             getResourcesForApplication for some packages, which silently
             swallows the resource-array path; the string path always works. -->
        <meta-data
            android:name="xposedscope"
            android:value="com.google.android.gms" />

    </application>

</manifest>
